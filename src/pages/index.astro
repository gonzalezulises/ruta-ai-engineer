---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const phases = [
  {
    id: 'fase-0',
    num: '0',
    title: 'Ingenieria de Software',
    duration: '8–10 semanas',
    quote: 'Sin esta base, todo lo que sigue es scripting glorificado. La mayoria de "AI engineers" fracasan aqui, no en el modelo.',
    objective: 'Dominar Python a nivel profesional, diseno de sistemas, testing, CI/CD y SQL como ciudadano de primera clase.',
    resources: [
      { name: 'CS50 (Harvard)', desc: 'Intro a CS con rigor', format: 'Video + Labs', url: 'https://cs50.harvard.edu/x/' },
      { name: 'Missing Semester (MIT)', desc: 'Shell, Git, debugging, profiling', format: 'Video + Exercises', url: 'https://missing.csail.mit.edu/' },
      { name: 'Python for Everybody (UMich / Dr. Chuck)', desc: '', format: 'Video + Libro', url: 'https://www.py4e.com/' },
      { name: 'Real Python', desc: 'Concurrencia, profiling, testing', format: 'Tutoriales', url: 'https://realpython.com/' },
      { name: 'SQLBolt', desc: 'SQL interactivo desde cero a avanzado', format: 'Ejercicios web', url: 'https://sqlbolt.com/' },
      { name: 'Select Star SQL', desc: 'SQL analitico con dataset real', format: 'Libro interactivo', url: 'https://selectstarsql.com/' },
      { name: 'System Design Primer (GitHub)', desc: 'Trade-offs, escalabilidad', format: 'Repositorio', url: 'https://github.com/donnemartin/system-design-primer' },
      { name: 'Designing Data-Intensive Applications (Kleppmann)', desc: 'Resumenes', format: 'Notas comunitarias', url: 'https://github.com/keyvanakbary/learning-notes/blob/master/books/designing-data-intensive-applications.md' },
    ],
    deliverable: 'Un proyecto Python con tests (pytest), CI/CD (GitHub Actions), SQL, y documentacion.',
  },
  {
    id: 'fase-1',
    num: '1',
    title: 'Fundamentos Matematicos con Proposito',
    duration: '6–8 semanas',
    quote: 'No para resolver ejercicios, sino para entender que hace un optimizer y por que ciertos modelos colapsan.',
    objective: 'Algebra lineal, calculo, probabilidad y estadistica bayesiana orientados a ML. Teoria de la informacion basica.',
    resources: [
      { name: '3Blue1Brown — Essence of Linear Algebra', desc: '', format: 'Video (16 eps)', url: 'https://www.3blue1brown.com/topics/linear-algebra' },
      { name: '3Blue1Brown — Essence of Calculus', desc: '', format: 'Video (12 eps)', url: 'https://www.3blue1brown.com/topics/calculus' },
      { name: '3Blue1Brown — Neural Networks', desc: 'Backprop visual', format: 'Video (6+ eps)', url: 'https://www.3blue1brown.com/topics/neural-networks' },
      { name: 'Khan Academy — Estadistica y Probabilidad', desc: '', format: 'Video + Ejercicios', url: 'https://www.khanacademy.org/math/statistics-probability' },
      { name: 'StatQuest (Josh Starmer)', desc: 'Bayesian, distribuciones, tests', format: 'YouTube', url: 'https://www.youtube.com/@statquest' },
      { name: 'Mathematics for Machine Learning (Deisenroth et al.)', desc: '', format: 'Libro PDF gratis', url: 'https://mml-book.github.io/' },
      { name: 'Information Theory (Chris Olah)', desc: '', format: 'Blog post', url: 'https://colah.github.io/posts/2015-09-Visual-Information/' },
    ],
    keyConcept: 'Entropia, KL divergence, cross-entropy loss — si no entiendes por que tu loss function es esa, estas operando a ciegas.',
  },
  {
    id: 'fase-2',
    num: '2',
    title: 'ML Clasico como Base de Criterio',
    duration: '6–8 semanas',
    quote: 'El objetivo no es "saber sklearn". Es desarrollar la intuicion de cuando NO usar deep learning.',
    objective: 'Bias-variance, regularizacion, feature engineering, seleccion de modelos. Metricas en contexto de negocio.',
    resources: [
      { name: 'Stanford CS229 (Andrew Ng)', desc: 'ML teorico riguroso', format: 'Video (YouTube)', url: 'https://www.youtube.com/playlist?list=PLoROMvodv4rMiGQp3WXShtMGgzqpfVfbU' },
      { name: 'CS229 Notas de curso', desc: '', format: 'PDF', url: 'https://cs229.stanford.edu/' },
      { name: 'Machine Learning Zoomcamp (DataTalks.Club)', desc: 'End-to-end con deployment', format: 'Video + Repo', url: 'https://github.com/DataTalksClub/machine-learning-zoomcamp' },
      { name: 'StatQuest — Machine Learning', desc: '', format: 'YouTube playlist', url: 'https://www.youtube.com/playlist?list=PLblh5JKOoLUICTaGLRoHQDuF_7q2GfuJF' },
      { name: 'Scikit-learn User Guide', desc: 'La mejor doc de ML aplicado', format: 'Documentacion', url: 'https://scikit-learn.org/stable/user_guide.html' },
      { name: 'Kaggle Learn', desc: 'ML practico con notebooks', format: 'Notebooks', url: 'https://www.kaggle.com/learn' },
    ],
    questions: [
      'Cuando random forest supera a un modelo lineal y por que?',
      'Que significa un recall de 0.95 en un detector de fraude vs. un recomendador de peliculas?',
      'Como detectas data leakage en cross-validation?',
    ],
  },
  {
    id: 'fase-3',
    num: '3',
    title: 'Deep Learning y Arquitecturas Modernas',
    duration: '8–10 semanas',
    quote: 'Transformers desde la mecanica, no desde la API.',
    objective: 'Entender attention, positional encoding, scaling laws. Training dynamics. PyTorch como herramienta, no como identidad.',
    resources: [
      { name: 'Andrej Karpathy — Neural Networks: Zero to Hero', desc: '', format: 'YouTube (7+ hrs)', url: 'https://karpathy.ai/zero-to-hero.html' },
      { name: 'Karpathy — Deep Dive into LLMs', desc: '', format: 'YouTube', url: 'https://www.youtube.com/@AndrejKarpathy' },
      { name: 'MIT 6.S191 — Intro to Deep Learning (2026)', desc: '', format: 'Video + Labs + Colab', url: 'https://introtodeeplearning.com/' },
      { name: 'Stanford CS224N — NLP with Deep Learning (2024)', desc: '', format: 'Video playlist', url: 'https://web.stanford.edu/class/cs224n/' },
      { name: 'The Illustrated Transformer (Jay Alammar)', desc: '', format: 'Blog post', url: 'https://jalammar.github.io/illustrated-transformer/' },
      { name: 'Attention Is All You Need (paper original)', desc: '', format: 'Paper', url: 'https://arxiv.org/abs/1706.03762' },
      { name: 'PyTorch Tutorials oficiales', desc: '', format: 'Documentacion', url: 'https://pytorch.org/tutorials/' },
      { name: 'd2l.ai — Dive into Deep Learning', desc: '', format: 'Libro interactivo', url: 'https://d2l.ai/' },
    ],
    extraReading: [
      { name: 'A Recipe for Training Neural Networks (Karpathy)', url: 'https://karpathy.github.io/2019/04/25/recipe/' },
      { name: 'Scaling Laws paper (Kaplan et al.)', url: 'https://arxiv.org/abs/2001.08361' },
    ],
  },
  {
    id: 'fase-4',
    num: '4',
    title: 'Ingenieria de LLMs',
    duration: '8–10 semanas',
    quote: 'El core diferenciador. Tres ramas: prompting, RAG, fine-tuning. La decision de cual aplicar es mas importante que saber ejecutar las tres.',
    objective: 'Dominar prompting como ingenieria, RAG como arquitectura de sistemas, fine-tuning como ultimo recurso informado.',
    resources: [
      { name: 'Hugging Face LLM Course', desc: 'Antes NLP Course, actualizado 2025', format: 'Curso interactivo', url: 'https://huggingface.co/learn/llm-course/' },
      { name: 'LLM Zoomcamp (DataTalks.Club)', desc: 'RAG, fine-tuning, produccion', format: 'Video + Repo gratis', url: 'https://github.com/DataTalksClub/llm-zoomcamp' },
      { name: 'Anthropic Prompt Engineering Guide', desc: '', format: 'Documentacion', url: 'https://docs.anthropic.com/en/docs/build-with-claude/prompt-engineering/' },
      { name: 'OpenAI Cookbook', desc: 'Patterns de produccion', format: 'GitHub', url: 'https://github.com/openai/openai-cookbook' },
      { name: 'A Survey of Techniques for Maximizing LLM Performance (OpenAI)', desc: '', format: 'Video', url: 'https://www.youtube.com/watch?v=ahnGLM-RC1Y' },
      { name: 'Chunking Strategies for RAG (Pinecone)', desc: '', format: 'Blog tecnico', url: 'https://www.pinecone.io/learn/chunking-strategies/' },
      { name: 'LoRA: Low-Rank Adaptation (paper)', desc: '', format: 'Paper', url: 'https://arxiv.org/abs/2106.09685' },
      { name: 'PEFT Documentation (Hugging Face)', desc: '', format: 'Docs', url: 'https://huggingface.co/docs/peft/' },
      { name: 'LLM-Twin Free Course (Iusztin et al.)', desc: 'RAG en produccion', format: 'GitHub + Medium', url: 'https://github.com/decodingml/llm-twin-course' },
    ],
    decisionTree: true,
  },
  {
    id: 'fase-5',
    num: '5',
    title: 'Sistemas de AI en Produccion',
    duration: '6–8 semanas',
    quote: 'Aqui muere el 90% de los "AI engineers" del mercado.',
    objective: 'Serving, optimizacion de inferencia, observabilidad, costos como restriccion de diseno, orquestacion de agentes.',
    resources: [
      { name: 'MLOps Zoomcamp (DataTalks.Club)', desc: 'MLflow, Docker, monitoring', format: 'Video + Repo gratis', url: 'https://github.com/DataTalksClub/mlops-zoomcamp' },
      { name: 'Made With ML (Goku Mohandas)', desc: 'MLOps end-to-end', format: 'Curso web gratis', url: 'https://madewithml.com/' },
      { name: 'Full Stack Deep Learning (2022)', desc: 'Produccion de ML', format: 'Video', url: 'https://fullstackdeeplearning.com/course/2022/' },
      { name: 'ML Engineering for Production (Andrew Ng / Coursera)', desc: 'Audit gratis', format: 'Video (audit free)', url: 'https://www.coursera.org/specializations/machine-learning-engineering-for-production-mlops' },
      { name: 'Evidently AI — ML Monitoring Course', desc: '', format: 'Video + GitHub', url: 'https://www.evidentlyai.com/ml-observability-course' },
      { name: 'vLLM Documentation', desc: 'Serving de alta performance', format: 'Docs', url: 'https://docs.vllm.ai/' },
      { name: 'llama.cpp', desc: 'Inferencia local optimizada', format: 'GitHub', url: 'https://github.com/ggml-org/llama.cpp' },
      { name: 'BentoML Documentation', desc: 'Model serving framework', format: 'Docs', url: 'https://docs.bentoml.com/' },
    ],
    metrics: [
      'Costo por query (tokens x precio + compute)',
      'Latencia p50/p95/p99',
      'Throughput (queries/segundo)',
      'Cache hit rate y su impacto en costos',
    ],
  },
  {
    id: 'fase-6',
    num: '6',
    title: 'Seguridad, Gobernanza y Evaluacion',
    duration: '4–6 semanas',
    quote: 'Lo que nadie ensena y todos necesitan.',
    objective: 'Prompt injection, evaluacion sistematica, red teaming, gobernanza de datos, etica practica (decisiones concretas, no filosofia).',
    resources: [
      { name: 'OWASP Top 10 for LLM Applications (2025)', desc: '', format: 'Guia + PDF', url: 'https://owasp.org/www-project-top-10-for-large-language-model-applications/' },
      { name: 'OWASP GenAI Security Project', desc: 'Detalle por vulnerabilidad', format: 'Web', url: 'https://genai.owasp.org/' },
      { name: 'Promptfoo', desc: 'Red teaming open-source para LLMs', format: 'GitHub + Docs', url: 'https://www.promptfoo.dev/' },
      { name: 'Simon Willison\'s Blog', desc: 'Prompt injection research', format: 'Blog', url: 'https://simonwillison.net/series/prompt-injection/' },
      { name: 'NIST AI Risk Management Framework', desc: '', format: 'PDF gratis', url: 'https://www.nist.gov/artificial-intelligence/executive-order-safe-secure-and-trustworthy-artificial-intelligence' },
      { name: 'Anthropic Research', desc: 'Constitutional AI, RLHF papers', format: 'Papers', url: 'https://www.anthropic.com/research' },
      { name: 'EU AI Act — Resumen ejecutivo', desc: '', format: 'Documentacion', url: 'https://artificialintelligenceact.eu/' },
    ],
    skills: [
      'Ejecutar un red team basico contra tu propia aplicacion LLM',
      'Implementar guardrails de entrada/salida',
      'Disenar un evaluation framework con metricas humanas + automaticas',
      'Identificar PII en pipelines de datos',
    ],
  },
];

const papersResources = [
  { name: 'ArXiv Sanity Lite (Karpathy)', format: 'Web', url: 'https://arxiv-sanity-lite.com/' },
  { name: 'Papers With Code', desc: 'Papers + implementaciones + benchmarks', format: 'Web', url: 'https://paperswithcode.com/' },
  { name: 'Yannic Kilcher', desc: 'Paper reviews con analisis critico', format: 'YouTube', url: 'https://www.youtube.com/@YannicKilcher' },
  { name: 'Two Minute Papers', desc: 'Overview rapido de papers nuevos', format: 'YouTube', url: 'https://www.youtube.com/@TwoMinutePapers' },
  { name: 'How to Read a Paper (Keshav)', desc: '', format: 'PDF (3 paginas)', url: 'https://svr-sk818-web.cl.cam.ac.uk/keshav/papers/07/paper-reading.pdf' },
];

const communityResources = [
  { name: 'Hugging Face Discord', type: 'Comunidad', url: 'https://huggingface.co/join/discord' },
  { name: 'MLOps Community Slack', type: 'Comunidad', url: 'https://mlops.community/' },
  { name: 'DataTalks.Club Slack', type: 'Comunidad', url: 'https://datatalks.club/' },
  { name: 'r/MachineLearning', type: 'Reddit', url: 'https://reddit.com/r/MachineLearning' },
  { name: 'r/LocalLLaMA', type: 'Reddit (inferencia local)', url: 'https://reddit.com/r/LocalLLaMA' },
  { name: 'The Batch (Andrew Ng)', type: 'Newsletter semanal', url: 'https://www.deeplearning.ai/the-batch/' },
  { name: 'Sebastian Raschka\'s Newsletter', type: 'Newsletter tecnica', url: 'https://magazine.sebastianraschka.com/' },
];

const excluded = [
  { item: 'C++ generico', reason: 'Solo relevante si vas a escribir kernels CUDA. Si llegas ahi, ya sabras que lo necesitas.' },
  { item: 'LangChain como skill central', reason: 'Es una abstraccion que cambia cada mes. Entiende los patterns subyacentes y cualquier framework sera trivial.' },
  { item: 'Certificaciones de cloud especificas', reason: 'AWS/GCP/Azure cambian pricing y servicios constantemente. Aprende los conceptos y el vendor sera intercambiable.' },
  { item: '"Prompt engineering" como disciplina aislada', reason: 'Esta integrado en Fase 4 como parte de la decision de ingenieria, no como habilidad decorativa.' },
];
---

<Layout
  title="Ruta Profesional: AI Software Engineer"
  description="Formacion alternativa de alta calidad para convertirte en AI Software Engineer. 12-18 meses, costo cero, todos los recursos gratuitos verificados."
>
  <!-- Header -->
  <header class="border-b border-surface-border sticky top-0 z-50 backdrop-blur-xl bg-surface/80">
    <div class="mx-auto max-w-4xl px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="h-8 w-8 rounded-lg bg-gradient-to-br from-accent-dim to-accent flex items-center justify-center text-xs font-bold text-white">AI</div>
        <span class="text-sm font-semibold text-text-secondary">Ruta AI Engineer</span>
      </div>
      <div class="flex items-center gap-4">
        <span class="text-xs text-text-muted hidden sm:inline">12–18 meses &middot; ~15h/semana &middot; Costo cero</span>
        <a
          href="https://github.com/gonzalezulises/ruta-ai-engineer"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-text-muted hover:text-text-primary transition-colors"
        >
          GitHub
        </a>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-4xl px-6 py-16">
    <!-- Hero -->
    <section class="mb-20">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-surface-border bg-surface-raised px-3 py-1 text-xs text-text-secondary">
        <span class="inline-block h-2 w-2 rounded-full bg-stitch-green animate-pulse"></span>
        Formacion alternativa de alta calidad
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
        Ruta Profesional:<br/>
        <span class="text-accent">AI Software Engineer</span>
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-text-secondary">
        Costo cero. 12–18 meses con dedicacion de ~15 horas/semana.
        Todos los recursos listados son de acceso gratuito verificado.
      </p>
      <div class="mt-4 flex flex-wrap gap-3 text-sm">
        <span class="rounded-full border border-surface-border bg-surface-alt px-3 py-1 text-text-muted">Prerrequisito: saber programar en al menos un lenguaje</span>
        <span class="rounded-full border border-surface-border bg-surface-alt px-3 py-1 text-text-muted">Algebra basica</span>
      </div>
    </section>

    <!-- TOC -->
    <nav class="mb-16 rounded-xl border border-surface-border bg-surface-raised p-6">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-text-muted">Contenido</h2>
      <ol class="columns-1 gap-x-8 space-y-2 text-sm sm:columns-2">
        {phases.map((p) => (
          <li>
            <a href={`#${p.id}`} class="text-accent hover:text-white transition-colors">
              Fase {p.num} — {p.title}
              <span class="ml-2 text-text-muted text-xs">({p.duration})</span>
            </a>
          </li>
        ))}
        <li><a href="#papers" class="text-accent hover:text-white transition-colors">Lectura Critica de Papers</a></li>
        <li><a href="#comunidades" class="text-accent hover:text-white transition-colors">Canales y Comunidades</a></li>
        <li><a href="#dependencias" class="text-accent hover:text-white transition-colors">Secuencia y Dependencias</a></li>
        <li><a href="#no-incluye" class="text-accent hover:text-white transition-colors">Lo que NO incluye</a></li>
      </ol>
    </nav>

    <!-- Phases -->
    {phases.map((phase) => (
      <section id={phase.id} class="mb-20">
        <!-- Phase header -->
        <div class="flex items-start gap-4 mb-6">
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-accent-dim text-sm font-bold text-white">{phase.num}</span>
          <div>
            <h2 class="text-2xl font-bold text-white">{phase.title}</h2>
            <span class="text-sm text-text-muted">{phase.duration}</span>
          </div>
        </div>

        <!-- Quote -->
        <blockquote class="mb-6 border-l-2 border-accent-dim pl-4 text-text-secondary italic">
          {phase.quote}
        </blockquote>

        <!-- Objective -->
        <div class="mb-6 rounded-lg border border-surface-border bg-surface-alt p-4">
          <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">Objetivo</span>
          <p class="mt-1 text-text-primary">{phase.objective}</p>
        </div>

        <!-- Resources table -->
        <h3 class="text-sm font-semibold uppercase tracking-wider text-text-muted mb-3">Recursos gratuitos</h3>
        <div class="overflow-x-auto mb-6">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-surface-border">
                <th class="py-3 pr-4 text-left font-semibold text-white">Recurso</th>
                <th class="py-3 pr-4 text-left font-semibold text-white hidden sm:table-cell">Formato</th>
                <th class="py-3 text-left font-semibold text-white w-16">Link</th>
              </tr>
            </thead>
            <tbody class="text-text-secondary">
              {phase.resources.map((r) => (
                <tr class="border-b border-surface-border/50">
                  <td class="py-3 pr-4">
                    <span class="font-medium text-text-primary">{r.name}</span>
                    {r.desc && <span class="text-text-muted"> — {r.desc}</span>}
                    <span class="sm:hidden block text-xs text-text-muted mt-0.5">{r.format}</span>
                  </td>
                  <td class="py-3 pr-4 text-text-muted hidden sm:table-cell">{r.format}</td>
                  <td class="py-3">
                    <a href={r.url} target="_blank" rel="noopener" class="text-accent hover:text-white transition-colors text-xs font-medium">Abrir &rarr;</a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Phase-specific extras -->
        {phase.deliverable && (
          <div class="rounded-lg border border-stitch-green/30 bg-stitch-green/5 p-4 text-sm">
            <strong class="text-stitch-green">Entregable de fase:</strong>
            <span class="text-text-secondary ml-1">{phase.deliverable}</span>
          </div>
        )}

        {phase.keyConcept && (
          <div class="rounded-lg border border-stitch-yellow/30 bg-stitch-yellow/5 p-4 text-sm">
            <strong class="text-stitch-yellow">Concepto clave:</strong>
            <span class="text-text-secondary ml-1">{phase.keyConcept}</span>
          </div>
        )}

        {phase.questions && (
          <div class="rounded-lg border border-accent-dim/30 bg-accent-dim/5 p-4 text-sm">
            <strong class="text-accent">Preguntas que debes poder responder:</strong>
            <ul class="mt-2 space-y-1 text-text-secondary">
              {phase.questions.map((q) => (
                <li class="flex items-start gap-2">
                  <span class="text-accent mt-1 text-xs">&#9656;</span>
                  <span>{q}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {phase.extraReading && (
          <div class="mt-4">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-text-muted mb-2">Lectura complementaria esencial</h3>
            <ul class="space-y-1 text-sm">
              {phase.extraReading.map((r) => (
                <li>
                  <a href={r.url} target="_blank" rel="noopener" class="text-accent hover:text-white transition-colors">{r.name} &rarr;</a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {phase.decisionTree && (
          <div class="mt-4 rounded-lg border border-surface-border bg-surface-alt p-5">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-text-muted mb-3">Decision critica que debes dominar</h3>
            <pre class="text-sm text-text-secondary leading-relaxed overflow-x-auto"><code>{`¿El conocimiento cambia frecuentemente?
  → Si → RAG
  → No → ¿El comportamiento del modelo necesita cambiar?
            → Si → ¿Tienes >1000 ejemplos de calidad?
                      → Si → Fine-tuning (LoRA/QLoRA)
                      → No → Few-shot prompting
            → No → Zero-shot con system prompt optimizado`}</code></pre>
          </div>
        )}

        {phase.metrics && (
          <div class="rounded-lg border border-stitch-red/30 bg-stitch-red/5 p-4 text-sm">
            <strong class="text-stitch-red">Metricas que debes saber calcular:</strong>
            <ul class="mt-2 space-y-1 text-text-secondary">
              {phase.metrics.map((m) => (
                <li class="flex items-start gap-2">
                  <span class="text-stitch-red mt-1 text-xs">&#9656;</span>
                  <span>{m}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {phase.skills && (
          <div class="rounded-lg border border-stitch-yellow/30 bg-stitch-yellow/5 p-4 text-sm">
            <strong class="text-stitch-yellow">Lo que debes poder hacer:</strong>
            <ul class="mt-2 space-y-1 text-text-secondary">
              {phase.skills.map((s) => (
                <li class="flex items-start gap-2">
                  <span class="text-stitch-yellow mt-1 text-xs">&#9656;</span>
                  <span>{s}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </section>
    ))}

    <!-- Papers -->
    <section id="papers" class="mb-20">
      <div class="flex items-start gap-4 mb-6">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-surface-raised border border-surface-border text-sm font-bold text-accent">T</span>
        <div>
          <h2 class="text-2xl font-bold text-white">Fase Transversal — Lectura Critica de Papers</h2>
          <span class="text-sm text-text-muted">Desde Fase 2 en adelante, 2-3 papers/semana</span>
        </div>
      </div>

      <blockquote class="mb-6 border-l-2 border-accent-dim pl-4 text-text-secondary italic">
        No como bullet point sino como practica semanal.
      </blockquote>

      <div class="overflow-x-auto mb-6">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-surface-border">
              <th class="py-3 pr-4 text-left font-semibold text-white">Recurso</th>
              <th class="py-3 pr-4 text-left font-semibold text-white hidden sm:table-cell">Formato</th>
              <th class="py-3 text-left font-semibold text-white w-16">Link</th>
            </tr>
          </thead>
          <tbody class="text-text-secondary">
            {papersResources.map((r) => (
              <tr class="border-b border-surface-border/50">
                <td class="py-3 pr-4">
                  <span class="font-medium text-text-primary">{r.name}</span>
                  {r.desc && <span class="text-text-muted"> — {r.desc}</span>}
                </td>
                <td class="py-3 pr-4 text-text-muted hidden sm:table-cell">{r.format}</td>
                <td class="py-3">
                  <a href={r.url} target="_blank" rel="noopener" class="text-accent hover:text-white transition-colors text-xs font-medium">Abrir &rarr;</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="rounded-lg border border-surface-border bg-surface-alt p-5">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-text-muted mb-3">Metodo de lectura para un paper</h3>
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent-dim text-xs font-bold text-white">1</span>
            <div>
              <span class="font-medium text-text-primary">Primera pasada (5 min)</span>
              <p class="text-sm text-text-muted">Abstract, figuras, conclusiones. ¿Cual es el claim?</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent-dim text-xs font-bold text-white">2</span>
            <div>
              <span class="font-medium text-text-primary">Segunda pasada (30 min)</span>
              <p class="text-sm text-text-muted">Metodologia, baselines, ablations. ¿La evidencia soporta el claim?</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent-dim text-xs font-bold text-white">3</span>
            <div>
              <span class="font-medium text-text-primary">Tercera pasada (si vale)</span>
              <p class="text-sm text-text-muted">¿Es reproducible? ¿Que asumen que no mencionan? ¿Aplica a tu contexto?</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Communities -->
    <section id="comunidades" class="mb-20">
      <h2 class="text-2xl font-bold text-white mb-6">Canales y Comunidades</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        {communityResources.map((r) => (
          <a href={r.url} target="_blank" rel="noopener" class="group rounded-lg border border-surface-border bg-surface-alt p-4 transition-colors hover:border-accent-dim">
            <span class="font-medium text-white group-hover:text-accent transition-colors">{r.name}</span>
            <p class="mt-1 text-xs text-text-muted">{r.type}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Dependency diagram -->
    <section id="dependencias" class="mb-20">
      <h2 class="text-2xl font-bold text-white mb-6">Secuencia y Dependencias</h2>
      <div class="rounded-xl border border-surface-border bg-surface-alt p-6 overflow-x-auto">
        <pre class="text-sm text-text-secondary leading-relaxed"><code>{`Fase 0 (SWE) ──────────────────────────────┐
                                           │
Fase 1 (Matematicas) ─────┐               │
                           ├── Fase 3 (DL) ── Fase 4 (LLMs) ── Fase 5 (Produccion)
Fase 2 (ML Clasico) ──────┘               │                          │
                                           │                          │
                                           └───── Fase 6 (Seguridad) ─┘

Fase Transversal (Papers) ── desde Fase 2 en adelante, 2-3 papers/semana`}</code></pre>
      </div>
    </section>

    <!-- What's NOT included -->
    <section id="no-incluye" class="mb-20">
      <h2 class="text-2xl font-bold text-white mb-6">Lo que esta ruta NO incluye (y por que)</h2>
      <div class="space-y-3">
        {excluded.map((e) => (
          <div class="rounded-lg border border-surface-border bg-surface-alt p-4">
            <span class="font-medium text-stitch-red">{e.item}</span>
            <p class="mt-1 text-sm text-text-muted">{e.reason}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Footer note -->
    <div class="text-center text-sm text-text-muted">
      <p>Ultima actualizacion: abril 2026</p>
      <p class="mt-1">Todos los recursos listados son de acceso gratuito verificado al momento de publicacion.</p>
    </div>
  </main>

  <!-- Footer -->
  <footer class="mt-12 border-t border-surface-border">
    <div class="mx-auto max-w-4xl px-6 py-8 text-center text-sm text-text-muted">
      <p>
        Creado por
        <a href="https://github.com/gonzalezulises" target="_blank" rel="noopener" class="text-accent hover:text-white transition-colors">Ulises Gonzalez</a>
      </p>
    </div>
  </footer>
</Layout>
